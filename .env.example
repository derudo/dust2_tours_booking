# Server Configuration
PORT=3000

# Email/SMTP Configuration (Optional - for sending actual emails)
# If left empty, bookings will still succeed and emails will be saved to a local "sent_emails.log" file.
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM_EMAIL=bookings@dust2.tours
SMTP_FROM_NAME="Dust2 Tours Agency"
